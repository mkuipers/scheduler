<% content_for :title, @poll.title.presence || "Meeting poll" %>

<header class="page-header">
  <p class="eyebrow">Meeting poll</p>
  <h1 class="page-title"><%= @poll.title.presence || "Untitled meeting" %></h1>
  <p class="meta-line">Organized by <strong><%= @poll.creator_name %></strong></p>
</header>

<% if flash[:notice].present? || flash[:alert].present? %>
  <div class="flash-stack">
    <% if flash[:notice].present? %>
      <p class="flash flash--notice" role="status"><%= flash[:notice] %></p>
    <% end %>
    <% if flash[:alert].present? %>
      <p class="flash flash--alert" role="alert"><%= flash[:alert] %></p>
    <% end %>
  </div>
<% end %>

<% if @is_creator %>
  <% slots_by_date = @poll.time_slots.ordered_by_date.group_by { |s| s.date.iso8601 }.transform_values { |arr| arr.map(&:display_label) } %>
  <% slot_minutes_by_date = @poll.time_slots.ordered_by_date.group_by { |s| s.date.iso8601 }.transform_values { |arr| arr.map { |s| [s.starts_at_minute, s.ends_at_minute] } } %>

  <div class="share-card">
    <p class="share-card__label">Share link</p>
    <p class="share-url"><%= poll_url(@poll.token) %></p>
  </div>

  <%= tag.section class: "section card card--pad calendar-card", data: {
        controller: "slot-calendar",
        slot_calendar_slots_value: slots_by_date,
        slot_calendar_slot_minutes_value: slot_minutes_by_date,
        slot_calendar_anchor_value: Time.zone.today.iso8601
      } do %>
    <h2 class="section-title">Add time slots</h2>
    <p class="calendar-hint">Choose a day on the calendar. You can type a time range or tap a preset to add it immediately for that date.</p>

    <div class="calendar__toolbar">
      <button type="button" class="btn btn--secondary calendar__nav-btn" data-action="slot-calendar#prevMonth" aria-label="Previous month">
        <span aria-hidden="true">‹</span>
      </button>
      <h3 class="calendar__month-label" data-slot-calendar-target="monthLabel"></h3>
      <button type="button" class="btn btn--secondary calendar__nav-btn" data-action="slot-calendar#nextMonth" aria-label="Next month">
        <span aria-hidden="true">›</span>
      </button>
    </div>

    <div class="calendar__grid" data-slot-calendar-target="grid" role="grid" aria-label="Month view"></div>

    <dialog class="slot-modal" data-slot-calendar-target="dialog" data-action="click->slot-calendar#backdropClose">
      <div class="slot-modal__panel" data-action="click->slot-calendar#stopPropagation">
        <div class="slot-modal__header">
          <h3 class="slot-modal__title" data-slot-calendar-target="modalTitle"></h3>
          <button type="button" class="slot-modal__close btn btn--ghost btn--sm" data-action="slot-calendar#closeModal" aria-label="Close">×</button>
        </div>

        <%= form_with url: poll_time_slots_url(@poll.token), scope: :time_slot, method: :post, html: { class: "form slot-modal__form", id: "slot-form-custom" } do |f| %>
          <%= f.hidden_field :date, value: "", id: "slot_form_custom_date", data: { slot_calendar_target: "dateField" } %>
          <%= f.hidden_field :starts_at_minute, value: "", id: "slot_form_custom_start" %>
          <%= f.hidden_field :ends_at_minute, value: "", id: "slot_form_custom_end" %>
          <div class="form__group">
            <%= f.label :time_window, "Time window", class: "form__label" %>
            <%= f.text_field :time_window,
                  placeholder: "e.g. 2pm–4pm",
                  autocomplete: "off",
                  id: "slot_form_custom_time_window",
                  data: { slot_calendar_target: "timeWindow" } %>
          </div>
          <div class="form__actions">
            <%= f.submit "Add time slot", class: "btn btn--primary" %>
          </div>
        <% end %>

        <% if @presets.any? %>
          <div class="slot-modal__presets">
            <p class="slot-modal__presets-label">Quick add (same times you used before)</p>
            <div class="preset-row preset-row--modal">
              <% @presets.each_with_index do |(start_min, end_min), idx| %>
                <% label = TimeSlot.new(starts_at_minute: start_min, ends_at_minute: end_min).display_label %>
                <span class="preset-wrap"
                      data-slot-calendar-target="presetWrap"
                      data-start-min="<%= start_min %>"
                      data-end-min="<%= end_min %>">
                  <%= form_with url: poll_time_slots_url(@poll.token), scope: :time_slot, method: :post, html: { class: "preset-quick-form", id: "slot-form-preset-#{idx}" } do |f| %>
                    <%= f.hidden_field :date, value: "", id: "slot_form_preset_#{idx}_date", data: { slot_calendar_target: "dateField" } %>
                    <%= f.hidden_field :starts_at_minute, value: start_min, id: "slot_form_preset_#{idx}_start" %>
                    <%= f.hidden_field :ends_at_minute, value: end_min, id: "slot_form_preset_#{idx}_end" %>
                    <%= f.submit label, class: "btn btn--ghost btn--sm" %>
                  <% end %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </dialog>
  <% end %>

  <% if @poll.time_slots.any? %>
    <section class="section">
      <h2 class="section-title">Scheduled options</h2>
      <ul class="slot-list">
        <% @poll.time_slots.ordered_by_date.each do |slot| %>
          <li class="slot-item">
            <span class="slot-item__text"><%= slot.date.strftime("%B %-d, %Y") %> · <%= slot.display_label %></span>
            <%= button_to "Remove", poll_time_slot_url(@poll.token, slot), method: :delete, class: "btn btn--danger btn--sm" %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

<% else %>
  <% if @participant.nil? %>
    <div class="card card--pad">
      <h2 class="section-title">Join this poll</h2>
      <p class="subtitle">Enter your name to mark when you’re free.</p>
      <%= form_with model: Participant.new, url: poll_participants_url(@poll.token), html: { class: "form" } do |f| %>
        <div class="form__group">
          <label for="participant_name" class="form__label">Your name</label>
          <%= f.text_field :name, id: "participant_name", required: true, autocomplete: "name", placeholder: "Your name" %>
        </div>
        <div class="form__actions">
          <%= f.submit "Join poll", class: "btn btn--primary" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card card--pad">
      <h2 class="section-title">Your availability, <%= @participant.name %></h2>
      <p class="subtitle">Choose yes, maybe, or no for each time.</p>
      <%= form_with url: poll_bulk_responses_url(@poll.token), method: :post, html: { class: "form" } do |f| %>
        <div class="availability-stack">
          <% responses_by_slot = @participant.responses.index_by(&:time_slot_id) %>
          <% @poll.time_slots.ordered_by_date.each do |slot| %>
            <% current_status = responses_by_slot[slot.id]&.status %>
            <fieldset class="availability-card">
              <legend><%= slot.date.strftime("%B %-d, %Y") %> · <%= slot.display_label %></legend>
              <div class="choice-grid">
                <label>
                  <input type="radio" name="responses[<%= slot.id %>]"
                         id="yes_<%= slot.id %>" value="yes"
                         <%= "checked" if current_status == "yes" %>>
                  Yes
                </label>
                <label>
                  <input type="radio" name="responses[<%= slot.id %>]"
                         id="maybe_<%= slot.id %>" value="maybe"
                         <%= "checked" if current_status == "maybe" %>>
                  Maybe
                </label>
                <label>
                  <input type="radio" name="responses[<%= slot.id %>]"
                         id="no_<%= slot.id %>" value="no"
                         <%= "checked" if current_status == "no" %>>
                  No
                </label>
              </div>
            </fieldset>
          <% end %>
        </div>
        <div class="form__actions">
          <%= f.submit "Save my availability", class: "btn btn--primary" %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
