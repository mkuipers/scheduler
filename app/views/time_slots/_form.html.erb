<%= form_with(model: time_slot) do |form| %>
  <% if time_slot.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(time_slot.errors.count, "error") %> prohibited this time_slot from being saved:</h2>

      <ul>
        <% time_slot.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :poll_id, style: "display: block" %>
    <%= form.text_field :poll_id %>
  </div>

  <div>
    <%= form.label :date, style: "display: block" %>
    <%= form.date_field :date %>
  </div>

  <div>
    <%= form.label :starts_at_minute, style: "display: block" %>
    <%= form.number_field :starts_at_minute %>
  </div>

  <div>
    <%= form.label :ends_at_minute, style: "display: block" %>
    <%= form.number_field :ends_at_minute %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
